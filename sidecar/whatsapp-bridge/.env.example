# Copy to .env and fill in.

# Where the HA add-on is reachable from this PC.
# LAN: http://homeassistant.local:8123/... no — the ingress endpoint isn't exposed.
# Direct to the add-on: expose port 5000 in the add-on's network config, then:
#   HA_URL=http://<ha-host>:5000
# Or, if running the sidecar on the HA host itself: http://127.0.0.1:5000
HA_URL=http://homeassistant.local:5000

# Must match the whatsapp_shared_secret option set in the add-on UI.
# Required for non-loopback requests. Generate with: openssl rand -hex 32
SHARED_SECRET=

# Comma-separated list of group JIDs to forward. Everything else is dropped.
# Leave empty on first run, use --list-groups to discover JIDs, then fill in.
# Example: GROUP_ALLOWLIST=1234567890-1600000000@g.us,9876543210-1700000000@g.us
GROUP_ALLOWLIST=

# Where Baileys persists its pairing/auth state. Safe to keep outside the repo.
AUTH_DIR=./auth

# Drop messages older than process start (avoids replaying history on first pair).
# Set to 0 to forward everything Baileys delivers (useful for debugging).
DROP_HISTORY=1
